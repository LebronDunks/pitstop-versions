    # ---- Status banner ----
    sw_issues    = len([r for r in sw_results if r.status == "warning" or
                        (r.status == "error" and r.installed != "Not installed")])
    diag_issues  = len([r for r in diag_results if r.severity == "critical"])
    total_issues = sw_issues + diag_issues
    status_color = {"green": C_GREEN, "yellow": C_YELLOW,
                    "red": C_RED, "grey": C_GREY}.get(status, C_GREY)
    status_text  = "All systems go — ready to race" if total_issues == 0 else "Needs attention"

    banner = tk.Frame(win, bg=C_BG, pady=10, padx=20)
    banner.pack(fill="x")
    status_dot = tk.Canvas(banner, width=14, height=14, bg=C_BG, highlightthickness=0)
    status_dot.pack(side="left", padx=(0, 8))
    status_dot.create_oval(1, 1, 13, 13, fill=status_color, outline="", tags="dot")
    status_lbl = tk.Label(banner, text=status_text, font=f_status, bg=C_BG, fg=status_color)
    status_lbl.pack(side="left")
    if total_issues > 0:
        pills = tk.Frame(banner, bg=C_BG)
        pills.pack(side="right")
        if sw_issues > 0:
            sw_pill = tk.Frame(pills, bg=C_YELLOW, padx=8, pady=2)
            sw_pill.pack(side="left", padx=(0, 4))
            tk.Label(sw_pill, text=f"Software: {sw_issues}",
                     font=tkfont.Font(family="DM Sans", size=8, weight="bold"),
                     bg=C_YELLOW, fg="#1A1A2E").pack()
        if diag_issues > 0:
            dg_color = C_RED
            dg_pill  = tk.Frame(pills, bg=dg_color, padx=8, pady=2)
            dg_pill.pack(side="left")
            tk.Label(dg_pill, text=f"Diagnostics: {diag_issues}",
                     font=tkfont.Font(family="DM Sans", size=8, weight="bold"),
                     bg=dg_color, fg="#1A1A2E").pack()

    tk.Frame(win, bg=C_BORDER, height=1).pack(fill="x")

    # ---- Tabs ----
    tab_frame = tk.Frame(win, bg=C_HOVER)
    tab_frame.pack(fill="x")

    def make_scroll_frame(parent):
        outer  = tk.Frame(parent, bg=C_BG)
        canvas = tk.Canvas(outer, bg=C_BG, highlightthickness=0)
        style_frame = tk.Frame(outer, bg=C_BORDER, width=6)
        style_frame.pack(side="right", fill="y")
        style_frame.pack_propagate(False)
        scrollbar = tk.Scrollbar(style_frame, orient="vertical", command=canvas.yview,
                                 bg=C_MUTED, troughcolor=C_BORDER, activebackground=C_TEXT,
                                 relief="flat", bd=0, width=6, highlightthickness=0,
                                 elementborderwidth=0)
        canvas.configure(yscrollcommand=scrollbar.set)
        scrollbar.pack(fill="both", expand=True)
        canvas.pack(side="left", fill="both", expand=True)
        inner    = tk.Frame(canvas, bg=C_BG)
        inner_id = canvas.create_window((0, 0), window=inner, anchor="nw")

        def on_configure(e):
            bbox = canvas.bbox("all")
            if bbox:
                canvas_h  = canvas.winfo_height()
                content_h = bbox[3] - bbox[1]
                if content_h <= canvas_h:
                    canvas.configure(scrollregion=(0, 0, 0, canvas_h))
                else:
                    canvas.configure(scrollregion=bbox)
            canvas.itemconfig(inner_id, width=canvas.winfo_width())

        inner.bind("<Configure>", on_configure)
        canvas.bind("<Configure>",
                    lambda e: (canvas.itemconfig(inner_id, width=e.width), on_configure(e)))

        def on_mousewheel(e):
            canvas.yview_scroll(int(-1 * (e.delta / 120)), "units")

        canvas._mw_handler = on_mousewheel
        return outer, canvas, inner

    sw_outer,   sw_canvas,   sw_inner_scroll   = make_scroll_frame(win)
    diag_outer, diag_canvas, diag_inner_scroll = make_scroll_frame(win)
    active_tab = {"current": "software"}

    def _bind_mousewheel(canvas):
        win.bind_all("<MouseWheel>", canvas._mw_handler)

    def switch_tab(name):
        active_tab["current"] = name
        if name == "software":
            diag_outer.pack_forget()
            sw_outer.pack(fill="both", expand=True)
            _bind_mousewheel(sw_canvas)
            sw_canvas.yview_moveto(0)
            tab_sw.configure(bg=C_BG, fg=C_TEXT, relief="flat", bd=0)
            tab_diag.configure(bg=C_PANEL, fg=C_MUTED, relief="flat", bd=0)
        else:
            sw_outer.pack_forget()
            diag_outer.pack(fill="both", expand=True)
            _bind_mousewheel(diag_canvas)
            diag_canvas.yview_moveto(0)
            tab_sw.configure(bg=C_PANEL, fg=C_MUTED, relief="flat", bd=0)
            tab_diag.configure(bg=C_BG, fg=C_TEXT, relief="flat", bd=0)

    tab_sw = tk.Label(tab_frame, text="Software", font=f_tab,
                      bg=C_BG, fg=C_TEXT, pady=9, cursor="hand2")
    tab_sw.pack(side="left", expand=True, fill="x")
    tab_sw.bind("<Button-1>", lambda e: switch_tab("software"))
    tab_diag = tk.Label(tab_frame, text="Diagnostics", font=f_tab,
                        bg=C_PANEL, fg=C_MUTED, pady=9, cursor="hand2")
    tab_diag.pack(side="left", expand=True, fill="x")
    tab_diag.bind("<Button-1>", lambda e: switch_tab("diag"))
    tk.Frame(win, bg=C_BORDER, height=1).pack(fill="x")
    sw_outer.pack(fill="both", expand=True)
    _bind_mousewheel(sw_canvas)

    # ---- Software tab rows ----
    def build_sw_row(parent, r):
        row_color = _sw_badge_color(r)
        badge_txt = STATUS_BADGES.get(r.status, "UNKNOWN")
        if r.status == "unknown" and r.installed == "Not installed":
            badge_txt = "MISSING"
        row = tk.Frame(parent, bg=C_BG, pady=8, padx=20)
        row.pack(fill="x")
        dot_c = tk.Canvas(row, width=8, height=8, bg=C_BG, highlightthickness=0)
        dot_c.pack(side="left", padx=(0, 10), pady=4)
        dot_c.create_oval(1, 1, 7, 7, fill=row_color, outline="")
        badge_frame = tk.Frame(row, bg=row_color, padx=8, pady=3)
        badge_frame.pack(side="right", padx=(8, 0))
        tk.Label(badge_frame, text=badge_txt, font=f_badge,
                 bg=row_color, fg="#1A1A2E").pack()
        info = tk.Frame(row, bg=C_BG)
        info.pack(side="left", fill="x", expand=True)
        tk.Label(info, text=r.label, font=f_label, bg=C_BG, fg=C_TEXT, anchor="w").pack(anchor="w")
        ver_text = f"{r.installed}  \u2192  {r.required}" if r.status == "warning" else r.installed
        tk.Label(info, text=ver_text, font=f_version, bg=C_BG, fg=C_MUTED, anchor="w").pack(anchor="w")

        if r.action:
            def _bind_click(widget, a):
                try:
                    widget.bind("<Button-1>", lambda e, x=a: perform_action(x))
                    widget.configure(cursor="hand2")
                except Exception:
                    pass
                for child in widget.winfo_children():
                    _bind_click(child, a)
            row.after(10, lambda w=row, a=r.action: _bind_click(w, a))

        def on_enter(e, f=row, bf=badge_frame):
            f.configure(bg=C_HOVER)
            for w in f.winfo_children():
                if w is bf: continue
                try: w.configure(bg=C_HOVER)
                except Exception: pass
                for ww in w.winfo_children():
                    try: ww.configure(bg=C_HOVER)
                    except Exception: pass

        def on_leave(e, f=row, bf=badge_frame):
            f.configure(bg=C_BG)
            for w in f.winfo_children():
                if w is bf: continue
                try: w.configure(bg=C_BG)
                except Exception: pass
                for ww in w.winfo_children():
                    try: ww.configure(bg=C_BG)
                    except Exception: pass

        row.bind("<Enter>", on_enter)
        row.bind("<Leave>", on_leave)

    def _build_sw_content(parent, results):
        for w in parent.winfo_children():
            w.destroy()
        inner = tk.Frame(parent, bg=C_BG, pady=4)
        inner.pack(fill="x")
        sw_info = tk.Frame(inner, bg="#0D1820", padx=12, pady=8)
        sw_info.pack(fill="x", padx=14, pady=(8, 4))
        tk.Frame(sw_info, bg="#1A3A5A", width=3).pack(side="left", fill="y", padx=(0, 10))
        sw_info_text = tk.Frame(sw_info, bg="#0D1820")
        sw_info_text.pack(side="left", fill="x", expand=True)
        tk.Label(sw_info_text, text="Your Podium 1 software",
                 font=tkfont.Font(family="DM Sans", size=11, weight="bold"),
                 bg="#0D1820", fg="#60A5FA", anchor="w").pack(anchor="w")
        tk.Label(sw_info_text,
                 text="These are the apps that keep your rig running. Click any item to open it. Yellow or red means an update is needed.",
                 font=tkfont.Font(family="DM Sans", size=10),
                 bg="#0D1820", fg="#4A7A9B", anchor="w",
                 wraplength=420, justify="left").pack(anchor="w")
        tk.Label(inner, text="COMPONENTS",
                 font=tkfont.Font(family="DM Sans", size=9),
                 bg=C_BG, fg="#6B6560", anchor="w", padx=20).pack(anchor="w", pady=(8, 2))
        for r in results:
            build_sw_row(inner, r)

    _build_sw_content(sw_inner_scroll, sw_results)

    # ---- Diagnostics tab rows ----
    def build_diag_row(parent, r):
        sev_color = DIAG_COLORS.get(r.severity, C_GREY)
        badge_txt = DIAG_BADGES.get(r.severity, "INFO")
        row = tk.Frame(parent, bg=C_BG, pady=10, padx=20)
        row.pack(fill="x")
        dot_c = tk.Canvas(row, width=8, height=8, bg=C_BG, highlightthickness=0)
        dot_c.pack(side="left", padx=(0, 10), pady=2, anchor="n")
        dot_c.create_oval(1, 1, 7, 7, fill=sev_color, outline="")
        top = tk.Frame(row, bg=C_BG)
        top.pack(fill="x")
        badge_frame = tk.Frame(top, bg=sev_color, padx=8, pady=3)
        badge_frame.pack(side="right", padx=(8, 0))
        tk.Label(badge_frame, text=badge_txt, font=f_badge,
                 bg=sev_color, fg="#1A1A2E").pack()
        tk.Label(top, text=r.title, font=f_label, bg=C_BG, fg=C_TEXT, anchor="w").pack(side="left", fill="x", expand=True)
        desc_lbl = tk.Label(row, text=r.description, font=f_diag,
                            bg=C_BG, fg=C_MUTED, anchor="w", wraplength=440, justify="left")
        desc_lbl.pack(fill="x", padx=(18, 8))

        def _update_wrap(e, lbl=desc_lbl):
            lbl.configure(wraplength=max(100, e.width - 28))
        row.bind("<Configure>", _update_wrap)

        if r.timestamp:
            tk.Label(row, text=r.timestamp, font=f_version,
                     bg=C_BG, fg="#6B6560", anchor="w").pack(fill="x", padx=(18, 8))

        def on_enter(e, f=row, bf=badge_frame):
            f.configure(bg=C_HOVER)
            for w in f.winfo_children():
                if w is bf: continue
                try: w.configure(bg=C_HOVER)
                except Exception: pass
                for ww in w.winfo_children():
                    if ww is bf: continue
                    try: ww.configure(bg=C_HOVER)
                    except Exception: pass

        def on_leave(e, f=row, bf=badge_frame):
            f.configure(bg=C_BG)
            for w in f.winfo_children():
                if w is bf: continue
                try: w.configure(bg=C_BG)
                except Exception: pass
                for ww in w.winfo_children():
                    if ww is bf: continue
                    try: ww.configure(bg=C_BG)
                    except Exception: pass

        row.bind("<Enter>", on_enter)
        row.bind("<Leave>", on_leave)

    def _build_diag_content(parent, results):
        for w in parent.winfo_children():
            w.destroy()
        inner = tk.Frame(parent, bg=C_BG)
        inner.pack(fill="x")
        dg_info = tk.Frame(inner, bg="#0D1810", padx=12, pady=8)
        dg_info.pack(fill="x", padx=14, pady=(8, 4))
        tk.Frame(dg_info, bg="#1A3A1A", width=3).pack(side="left", fill="y", padx=(0, 10))
        dg_info_text = tk.Frame(dg_info, bg="#0D1810")
        dg_info_text.pack(side="left", fill="x", expand=True)
        tk.Label(dg_info_text, text="System health monitor",
                 font=tkfont.Font(family="DM Sans", size=11, weight="bold"),
                 bg="#0D1810", fg="#2ECC71", anchor="w").pack(anchor="w")
        tk.Label(dg_info_text,
                 text="PitStop monitors your rig 24/7 for crashes, USB drops, overheating, and other issues that can interrupt your session.",
                 font=tkfont.Font(family="DM Sans", size=10),
                 bg="#0D1810", fg="#3A8A6A", anchor="w",
                 wraplength=420, justify="left").pack(anchor="w")
        checked_time = datetime.now().strftime("Last checked %b %d at %I:%M %p")
        tk.Label(inner, text=checked_time.upper(),
                 font=tkfont.Font(family="DM Sans", size=9),
                 bg=C_BG, fg="#6B6560", anchor="w", padx=20).pack(anchor="w", pady=(8, 2))
        if results:
            order = {"critical": 0, "warning": 1, "info": 2, "clear": 3}
            sorted_diags = sorted(results, key=lambda r: order.get(r.severity, 4))
            for r in sorted_diags:
                build_diag_row(inner, r)
        else:
            tk.Label(inner, text="Running diagnostics...", font=f_version,
                     bg=C_BG, fg=C_MUTED, padx=16, pady=12).pack(anchor="w")

    _build_diag_content(diag_inner_scroll, diag_results)

    # ---- Footer ----
    tk.Frame(win, bg=C_BORDER, height=1).pack(fill="x")
    footer = tk.Frame(win, bg=C_BG, pady=4)
    footer.pack(fill="x")

    def make_footer_btn(parent, text, command):
        btn = tk.Label(parent, text=text, font=f_action,
                       bg=C_BG, fg=C_MUTED, padx=20, pady=10, cursor="hand2", anchor="w")
        btn.pack(fill="x")
        btn.bind("<Button-1>", lambda e: command())
        btn.bind("<Enter>", lambda e: btn.configure(bg=C_BTN_HOVER, fg=C_TEXT))
        btn.bind("<Leave>", lambda e: btn.configure(bg=C_BG, fg=C_MUTED))
        return btn

    def do_check_now():
        win.destroy()
        on_check_now()

    make_footer_btn(footer, "Check now",    do_check_now)
    make_footer_btn(footer, "View log",     on_view_log)
    make_footer_btn(footer, "Quit PitStop", lambda: [win.destroy(), on_quit()])

    # ---- Save size on close ----
    def on_close():
        try:
            cfg = load_config()
            cfg["popup_width"]  = win.winfo_width()
            cfg["popup_height"] = win.winfo_height()
            save_config(cfg)
        except Exception:
            pass
        win.destroy()

    win.protocol("WM_DELETE_WINDOW", on_close)

    # ---- Position: bottom-right above taskbar ----
    win.update_idletasks()
    sw = win.winfo_screenwidth()
    sh = win.winfo_screenheight()
    x  = sw - WINDOW_W - 16
    y  = sh - WINDOW_H - 56
    win.geometry(f"{WINDOW_W}x{WINDOW_H}+{x}+{y}")
    win.minsize(400, 400)

    def _apply_refresh(new_sw, new_diag, new_st):
        try:
            if not win.winfo_exists():
                return
            for widget in sw_inner_scroll.winfo_children():
                widget.destroy()
            for widget in diag_inner_scroll.winfo_children():
                widget.destroy()
            _build_sw_content(sw_inner_scroll, new_sw)
            _build_diag_content(diag_inner_scroll, new_diag)
            new_sw_issues   = len([r for r in new_sw if r.status == "warning" or
                                   (r.status == "error" and r.installed != "Not installed")])
            new_diag_issues = len([r for r in new_diag if r.severity == "critical"])
            new_color = {"green": C_GREEN, "yellow": C_YELLOW,
                         "red": C_RED, "grey": C_GREY}.get(new_st, C_GREY)
            status_dot.itemconfig("all", fill=new_color)
            if new_sw_issues == 0 and new_diag_issues == 0:
                status_lbl.configure(text="All systems go — ready to race", fg=new_color)
            else:
                status_lbl.configure(text="Needs attention", fg=new_color)
        except Exception as exc:
            log.warning("Refresh apply failed: %s", exc)

    def _do_refresh():
        try:
            fetch_manifest(force=True)
            new_sw = run_checks_func()
            new_st = overall_status(new_sw) if new_sw else "grey"
            try:
                win.after(0, lambda: _apply_refresh(new_sw, [], new_st))
            except Exception:
                pass
        except Exception as exc:
            log.warning("Background refresh failed: %s", exc)

    _refresh_running = {"active": False}

    def _on_focus_in(e):
        if _refresh_running["active"]:
            return
        _refresh_running["active"] = True
        def _run():
            _do_refresh()
            _refresh_running["active"] = False
        threading.Thread(target=_run, daemon=True).start()

    win.bind("<FocusIn>", _on_focus_in)
    root.wait_window(win)


# ---------------------------------------------------------------------------
# Tray application
# ---------------------------------------------------------------------------

class PitStopApp:
    def __init__(self):
        self._sw_results = []
        self._status     = "grey"
        self._lock       = threading.Lock()
        self._icon       = None
        self._stop_event = threading.Event()
        self._tk_queue   = []
        self._tk_lock    = threading.Lock()
        self._icon_cache = {}  # exe_path -> base64 data URL, populated at startup

    def _cache_icons(self):
        """Run once at startup in a background thread.
        Pre-extracts all app icons so get_app_icon() is an instant cache hit."""
        try:
            manifest = fetch_manifest()
            components = manifest.get("components", {})
            profile_name, enabled_addons = get_profile()
            profiles_def = manifest.get("profiles", {})
            addons_def   = manifest.get("addons", {})
            active_keys  = list(profiles_def.get(profile_name, {}).get("components", []))
            for addon_key in enabled_addons:
                comp_key = addons_def.get(addon_key, {}).get("component")
                if comp_key and comp_key not in active_keys:
                    active_keys.append(comp_key)
            for key in active_keys:
                comp = components.get(key, {})
                hint = comp.get("install_path_hint", "")
                exe  = comp.get("exe_name", "")
                if hint and exe:
                    exe_path = str(Path(hint) / exe)
                    if Path(exe_path).exists():
                        result = _extract_icon_to_base64(exe_path)
                        if result:
                            self._icon_cache[exe_path] = result
                            log.info("Icon cached for %s", key)
        except Exception as exc:
            log.warning("Icon cache build failed: %s", exc)

    def _check_loop(self):
        while not self._stop_event.is_set():
            log.info("Starting check cycle...")
            sw_results = run_checks_func()
            status     = overall_status(sw_results) if sw_results else "grey"
            with self._lock:
                self._sw_results = sw_results
                self._status     = status
            if self._icon:
                self._icon.icon  = make_icon(status)
                self._icon.title = self._tooltip()
                self._icon.menu  = self._build_tray_menu()
                try:
                    self._icon.update_menu()
                except Exception:
                    pass
            log.info("Check cycle complete — status=%s", status)
            self._stop_event.wait(CHECK_INTERVAL_SECONDS)

    def _tooltip(self) -> str:
        with self._lock:
            sw = list(self._sw_results)
        issues = [r.label for r in sw if r.status in ("warning", "error")]
        if not issues:
            return "PitStop — All systems go"
        return "PitStop — Needs attention: " + ", ".join(issues[:3])

    def _build_tray_menu(self) -> Menu:
        return Menu(
            item("Open PitStop", self._on_open_popup, default=True),
            Menu.SEPARATOR,
            item("Check now", self._on_check_now),
            item("View log",  self._on_view_log),
            item("Quit",      self._on_quit),
        )

    def _on_open_popup(self, icon=None, menu_item=None):
        threading.Thread(target=self._refresh_and_open, daemon=True).start()

    def _refresh_and_open(self):
        fetch_manifest(force=True)
        sw_results = run_checks_func()
        status     = overall_status(sw_results) if sw_results else "grey"
        with self._lock:
            self._sw_results = sw_results
            self._status     = status
        if self._icon:
            self._icon.icon  = make_icon(status)
            self._icon.title = self._tooltip()
            try:
                self._icon.update_menu()
            except Exception:
                pass
        with self._tk_lock:
            self._tk_queue.append(("webview", sw_results, [], status))

    def _on_check_now(self, icon=None, menu_item=None):
        self._stop_event.set()
        self._stop_event.clear()
        threading.Thread(target=self._check_loop, daemon=True).start()

    def _on_view_log(self, icon=None, menu_item=None):
        subprocess.Popen(["notepad.exe", str(LOG_FILE)],
                         creationflags=subprocess.CREATE_NO_WINDOW)

    def _on_quit(self, icon=None, menu_item=None):
        log.info("PitStop exiting.")
        self._stop_event.set()
        if self._icon:
            self._icon.stop()

    def _tk_pump(self):
        with self._tk_lock:
            pending = list(self._tk_queue)
            self._tk_queue.clear()
        for msg in pending:
            if msg[0] == "webview":
                _, sw, diag, st = msg
                open_webview_popup(sw, diag, st, app=self)


    def run(self):
        log.info("PitStop starting — profile: %s, addons: %s", *get_profile())
        global _tk_root
        _tk_root = tk.Tk()
        _tk_root.withdraw()
        threading.Thread(target=self._check_loop, daemon=True).start()
        threading.Thread(target=self._cache_icons, daemon=True).start()
        self._icon = pystray.Icon(
            name="PitStop",
            icon=make_icon("grey"),
            title="PitStop — Starting...",
            menu=self._build_tray_menu(),
        )
        tray_thread = threading.Thread(target=self._icon.run, daemon=True)
        tray_thread.start()
        while tray_thread.is_alive():
            try:
                _tk_root.update()
            except Exception:
                pass
            self._tk_pump()
            time.sleep(0.05)
        log.info("PitStop exited.")


if __name__ == "__main__":
    import socket
    _lock_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        _lock_socket.bind(("127.0.0.1", 49152))
    except OSError:
        log.warning("PitStop already running — exiting.")
        sys.exit(0)
    app = PitStopApp()
    app.run()
