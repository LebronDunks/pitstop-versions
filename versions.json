    "/refs/heads/main/versions.json"
)

CHECK_INTERVAL_SECONDS = 60 * 60
CACHE_TTL_SECONDS      = 60 * 30

def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except Exception:
            pass
    return {}

def save_config(cfg: dict):
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))

def get_profile() -> tuple[str, list[str]]:
    cfg = load_config()
    return cfg.get("profile", "moza-build"), cfg.get("addons", [])

def get_customer_profile() -> dict:
    """Return saved customer profile from config, or empty dict if not logged in."""
    cfg = load_config()
    return cfg.get("customer_profile", {})

def save_customer_profile(profile: dict):
    """Save customer profile to config.json."""
    cfg = load_config()
    cfg["customer_profile"] = profile
    save_config(cfg)

def resolve_components_from_customer(profile: dict) -> list:
    """
    Map customer hardware fields from Nathaniels database to component keys.
    Falls back to the legacy profile system if no customer profile is present.
    """
    if not profile:
        profile_name, addons = get_profile()
        manifest = fetch_manifest()
        profiles_def = manifest.get("profiles", {})
        addons_def   = manifest.get("addons", {})
        active_keys  = list(profiles_def.get(profile_name, {}).get("components", []))
        for addon_key in addons:
            comp_key = addons_def.get(addon_key, {}).get("component")
            if comp_key and comp_key not in active_keys:
                active_keys.append(comp_key)
        return active_keys

    keys = ["nvidia_driver", "windows_update", "simhub"]

    wheelbase = (profile.get("wheelbase") or "").lower()
    if "asetek" in wheelbase:
        keys.append("asetek_racehub")
    if "moza" in wheelbase:
        keys.append("moza_pithouse")
    if "simucube" in wheelbase:
        keys.append("simucube_truedrive")

    pedals = (profile.get("pedals") or "").lower()
    if "heusinkveld" in pedals:
        if "heusinkveld_app" not in keys:
            keys.append("heusinkveld_app")

    addons = (profile.get("addOns") or "").lower()
    if "stream deck" in addons or "streamdeck" in addons:
        keys.append("streamdeck")
    if "sensit" in addons:
        keys.append("sensit_haptics")

    return keys

