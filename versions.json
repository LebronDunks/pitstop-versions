def _get_tk_root():
    return _tk_root

def _results_to_json(sw_results: list, diag_results: list, status: str) -> dict:
    profile_label = get_customer_display_name()
    sw_rows = []
    for r in sw_results:
        sw_rows.append({
            "key":       r.key,
            "name":      r.label,
            "installed": r.installed,
            "approved":  r.required,
            "status":    r.status,
            "message":   r.message,
            "action":    r.action or "",
        })
    diag_rows = []
    for r in diag_results:
        diag_rows.append({
            "key":         r.key,
            "title":       r.title,
            "severity":    r.severity,
            "description": r.description,
            "time":        r.timestamp or "",
        })
    return {
        "sw":           sw_rows,
        "diag":         diag_rows,
        "status":       status,
        "profile":      profile_label,
        "last_checked": datetime.now().strftime("%b %d at %I:%M %p"),
    }

# ---------------------------------------------------------------------------
# Icon extraction helper -- runs in background at startup, not at popup time
# ---------------------------------------------------------------------------

def _extract_icon_to_base64(exe_path: str) -> str:
    """Extract the icon from an exe and return it as a base64 PNG data URL.
    All GDI work happens here in a background thread so the UI is never blocked."""
    try:
        import base64
        import io
        from PIL import Image
        import win32gui
        import win32con
        import win32ui

        exe = exe_path.replace("/", "\\")
        if not Path(exe).exists():
            return ""

        large, small = win32gui.ExtractIconEx(exe, 0)
        if not large and not small:
            return ""

        hicon = large[0] if large else small[0]

        # Create a DC and bitmap to draw the icon into
        hdc = win32ui.CreateDCFromHandle(win32gui.GetDC(0))
        hbmp = win32ui.CreateBitmap()
        hbmp.CreateCompatibleBitmap(hdc, 32, 32)
        hdc_mem = hdc.CreateCompatibleDC()
        hdc_mem.SelectObject(hbmp)
        hdc_mem.FillSolidRect((0, 0, 32, 32), win32gui.GetSysColor(win32con.COLOR_WINDOW))
        win32gui.DrawIconEx(hdc_mem.GetSafeHdc(), 0, 0, hicon, 32, 32, 0, None, win32con.DI_NORMAL)

        # Convert HBITMAP to PIL Image
        bmpinfo = hbmp.GetInfo()
        bmpstr = hbmp.GetBitmapBits(True)
        img = Image.frombuffer("RGB", (bmpinfo["bmWidth"], bmpinfo["bmHeight"]), bmpstr, "raw", "BGRX", 0, 1)
        img = img.resize((36, 36), Image.LANCZOS)

        # Convert to base64 PNG
        buf = io.BytesIO()
        img.save(buf, format="PNG")
        b64 = base64.b64encode(buf.getvalue()).decode("ascii")

        # Cleanup
        win32gui.DestroyIcon(hicon)
        if large:
            for h in large[1:]: win32gui.DestroyIcon(h)
        if small:
            for h in small: win32gui.DestroyIcon(h)
        hdc_mem.DeleteDC()
        hdc.DeleteDC()

        return f"data:image/png;base64,{b64}"
    except Exception as exc:
        log.warning("_extract_icon_to_base64 failed for %s: %s", exe_path, exc)
        return ""


class PitStopAPI:
    def __init__(self, app):
        self._app = app
        self._win = None

    def run_checks(self):
        fetch_manifest(force=True)
        sw = run_checks_func()
        st = overall_status(sw) if sw else "grey"
        with self._app._lock:
            self._app._sw_results = sw
            self._app._status     = st
        if self._app._icon:
            self._app._icon.icon  = make_icon(st)
            self._app._icon.title = self._app._tooltip()
            try:
                self._app._icon.update_menu()
            except Exception:
                pass
        return _results_to_json(sw, [], st)

    def perform_action(self, action: str, key: str = ""):
        if action:
            threading.Thread(target=perform_action, args=(action,), daemon=True).start()

    def save_profile(self, profile: dict):
        """Called by JS after successful login to save customer profile."""
        try:
            save_customer_profile(profile)
            log.info("Customer profile saved: %s", profile.get("name", "unknown"))
        except Exception as exc:
            log.warning("Failed to save customer profile: %s", exc)

    def get_saved_profile(self):
        """Called by JS to check if a customer is already logged in."""
        return get_customer_profile()

    def logout(self):
        """Called by JS to clear the saved customer profile."""
        try:
            cfg = load_config()
            cfg.pop("customer_profile", None)
            save_config(cfg)
            log.info("Customer logged out")
        except Exception as exc:
            log.warning("Logout failed: %s", exc)

    def close_window(self):
        if self._win:
            try:
                self._win.destroy()
            except Exception:
                pass

    def toggle_fullscreen(self):
        if self._win:
            try:
                self._win.toggle_fullscreen()
            except Exception:
                pass

    def start_drag(self):
        """Called by JS to initiate window drag (frameless window support)."""
        if self._win:
            try:
                self._win.move_window()
            except Exception:
                pass

    def get_app_icon(self, exe_path: str) -> str:
        """Return cached icon for exe_path. Icons are pre-loaded at startup
        so this is an instant dict lookup with zero GDI work at popup time."""
        return self._app._icon_cache.get(exe_path.replace("/", "\\"), "")

    def start_resize(self, direction: str):
        """Called by JS to initiate window resize from an edge/corner."""
        if self._win:
            try:
                self._win.resize_window(direction)
            except Exception:
                pass


def open_webview_popup(sw_results, diag_results, status, app):
    """Open the pywebview popup window with the PitStop UI."""
    ui_path = Path(sys.argv[0]).resolve().parent / "pitstop_ui.html"
    if not ui_path.exists():
        ui_path = Path(__file__).parent / "pitstop_ui.html"
    if not ui_path.exists():
        log.error("pitstop_ui.html not found — falling back to tkinter popup")
        show_popup(sw_results, diag_results, status,
                   on_check_now=app._on_check_now,
                   on_view_log=app._on_view_log,
                   on_quit=app._on_quit)
        return

    api = PitStopAPI(app)
    initial_data = _results_to_json(sw_results, diag_results, status)

    import ctypes
    screen_w = ctypes.windll.user32.GetSystemMetrics(0)
    screen_h = ctypes.windll.user32.GetSystemMetrics(1)
    WIN_W, WIN_H = 480, 660
    x = screen_w - WIN_W - 16
    y = screen_h - WIN_H - 56

    win = webview.create_window(
        title="PitStop",
        url=str(ui_path),
        js_api=api,
        width=WIN_W,
        height=WIN_H,
        x=x,
        y=y,
        resizable=True,
        frameless=True,
        on_top=True,
        background_color="#12121E",
        min_size=(420, 500),
    )
    api._win = win
    webview.start(debug=False)


