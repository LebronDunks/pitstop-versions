_COLOR_MAP = {
    "green":  "#22C55E",
    "yellow": "#F59E0B",
    "red":    "#CC1122",
    "grey":   "#555555",
}

def _load_logo() -> "Image.Image | None":
    exe_dir = Path(sys.argv[0]).resolve().parent
    candidates = [
        exe_dir / "p1logo.png",
        Path(sys.executable).parent / "p1logo.png",
        Path(__file__).parent / "p1logo.png",
        Path(__file__).parent / "dist" / "p1logo.png",
    ]
    for c in candidates:
        if c.exists():
            log.info("Logo found: %s", c)
            return Image.open(c).convert("RGBA")
    log.warning("P1 logo not found — checked: %s", [str(c) for c in candidates])
    return None


def make_icon(color_name: str) -> Image.Image:
    size  = 64
    color = _COLOR_MAP.get(color_name, _COLOR_MAP["grey"])
    logo = _load_logo()
    if logo:
        img  = Image.new("RGBA", (size, size), (0, 0, 0, 0))
        logo = logo.resize((size, size), Image.LANCZOS)
        img.paste(logo, (0, 0), logo)
        draw = ImageDraw.Draw(img)
        draw.ellipse([44, 44, 62, 62], fill="#1A1A2E")
        draw.ellipse([47, 47, 61, 61], fill=color)
        return img
    img   = Image.new("RGBA", (size, size), (0, 0, 0, 0))
    draw  = ImageDraw.Draw(img)
    draw.ellipse([2, 2, size - 3, size - 3], fill="#1A1A2E")
    draw.ellipse([6, 6, size - 7, size - 7], outline=color, width=4)
    draw.rectangle([18, 20, 23, 44], fill=color)
    draw.rectangle([23, 20, 33, 25], fill=color)
    draw.rectangle([23, 30, 33, 35], fill=color)
    draw.rectangle([33, 20, 38, 35], fill=color)
    draw.rectangle([42, 20, 47, 44], fill=color)
    draw.rectangle([39, 40, 50, 44], fill=color)
    return img

def ver_gte(installed: str, required: str) -> bool:
    try:
        return pkg_version.parse(installed) >= pkg_version.parse(required)
    except Exception:
        return installed >= required

_manifest_cache: dict = {}
_manifest_fetched_at: float = 0.0

def fetch_manifest(force: bool = False) -> dict:
    global _manifest_cache, _manifest_fetched_at
    now = time.time()
    if not force and _manifest_cache and (now - _manifest_fetched_at) < CACHE_TTL_SECONDS:
        return _manifest_cache
    try:
        resp = requests.get(VERSIONS_URL, timeout=10)
        resp.raise_for_status()
        _manifest_cache = resp.json()
        _manifest_fetched_at = now
        log.info("Manifest fetched OK")
    except Exception as exc:
        log.warning("Could not fetch manifest: %s", exc)
        if not _manifest_cache:
            local = Path(sys.executable).parent / "versions.json"
            if local.exists():
                _manifest_cache = json.loads(local.read_text())
                log.info("Loaded bundled versions.json as fallback")
    return _manifest_cache

class CheckResult:
    def __init__(self, key, label, status, installed, required, message, action=""):
        self.key       = key
        self.label     = label
        self.status    = status
        self.installed = installed
        self.required  = required
        self.message   = message
        self.action    = action

class DiagResult:
    def __init__(self, key, title, severity, description, timestamp=""):
        self.key         = key
        self.title       = title
        self.severity    = severity
        self.description = description
        self.timestamp   = timestamp

def _reg_read(hive_str: str, key_path: str, value_name: str):
    hive_map = {"HKLM": winreg.HKEY_LOCAL_MACHINE, "HKCU": winreg.HKEY_CURRENT_USER}
    parts = hive_str.split("\\", 1)
    hive  = hive_map.get(parts[0])
    if not hive:
        return None
    sub = parts[1] if len(parts) > 1 else ""

    # Try the path as given first, then WOW6432Node fallback for 32-bit apps on 64-bit Windows
    candidates = [sub]
    if sub.upper().startswith("SOFTWARE\\") and "WOW6432NODE" not in sub.upper():
        candidates.append("SOFTWARE\\WOW6432Node\\" + sub[len("SOFTWARE\\"):])

    for path in candidates:
        try:
            with winreg.OpenKey(hive, path) as k:
                val, _ = winreg.QueryValueEx(k, value_name)
                return str(val)
        except Exception:
            continue
    return None

def _silent_ps(cmd: list, timeout: int = 10) -> str:
    si = subprocess.STARTUPINFO()
    si.dwFlags |= subprocess.STARTF_USESHOWWINDOW
    si.wShowWindow = 0
    try:
        result = subprocess.check_output(
            cmd,
            timeout=timeout,
            creationflags=subprocess.CREATE_NO_WINDOW,
            startupinfo=si,
            stderr=subprocess.DEVNULL,
        )
        return result.decode(errors="replace").strip()
    except Exception as exc:
        log.warning("Silent PS failed: %s", exc)
        return ""

def _get_exe_version(exe_path: Path):
    result = _silent_ps(
        ["powershell", "-NonInteractive", "-NoProfile", "-WindowStyle", "Hidden",
         "-command", f"(Get-Item '{exe_path}').VersionInfo.FileVersion"],
        timeout=10,
    )
    return result if result else None

def _get_exe_product_version(exe_path: Path):
    # Reads ProductVersion (user-facing version shown inside the app)
    # instead of FileVersion (internal build number).
    result = _silent_ps(
        ["powershell", "-NonInteractive", "-NoProfile", "-WindowStyle", "Hidden",
         "-command", f"(Get-Item '{exe_path}').VersionInfo.ProductVersion"],
        timeout=10,
    )
    return result if result else None

def check_nvidia_driver(comp):
    approved  = comp.get("approved_version", "")
    installed = None
    try:
        si = subprocess.STARTUPINFO()
        si.dwFlags |= subprocess.STARTF_USESHOWWINDOW
        si.wShowWindow = 0
        out = subprocess.check_output(
            ["nvidia-smi", "--query-gpu=driver_version", "--format=csv,noheader"],
            timeout=10,
            creationflags=subprocess.CREATE_NO_WINDOW,
            startupinfo=si,
            stderr=subprocess.DEVNULL,
        ).decode().strip().split("\n")[0].strip()
        installed = out
    except Exception as exc:
        log.warning("nvidia-smi failed: %s", exc)

    if not installed:
        return CheckResult("nvidia_driver", comp["label"], "unknown",
                           "Not found", approved,
                           "NVIDIA driver not detected.",
                           comp.get("update_url", ""))
    if ver_gte(installed, approved):
        return CheckResult("nvidia_driver", comp["label"], "ok",
                           installed, approved,
                           f"GPU driver v{installed} is current.",
                           "open_nvidia_app")
    else:
        return CheckResult("nvidia_driver", comp["label"], "warning",
                           installed, approved,
                           f"GPU driver update available: {installed} -> {approved}",
                           "open_nvidia_app")

def check_windows_update(comp):
    try:
        import pythoncom
        import win32com.client
        pythoncom.CoInitialize()
        wua      = win32com.client.Dispatch("Microsoft.Update.Session")
        searcher = wua.CreateUpdateSearcher()
        result   = searcher.Search("IsInstalled=0 and IsHidden=0 and Type='Software'")
        count    = result.Updates.Count
        if count == 0:
            return CheckResult("windows_update", comp["label"], "ok",
                               "Up to date", "Up to date",
                               "Windows is up to date.",
                               "open_windows_update")
        elif count <= 5:
            return CheckResult("windows_update", comp["label"], "warning",
                               f"{count} pending", "0 pending",
                               f"{count} update(s) pending.",
                               "open_windows_update")
        else:
            return CheckResult("windows_update", comp["label"], "error",
                               f"{count} pending", "0 pending",
                               f"{count} updates pending — action needed.",
                               "open_windows_update")
    except Exception as exc:
        log.warning("Windows Update check failed: %s", exc)
        return CheckResult("windows_update", comp["label"], "unknown",
                           "Unknown", "Unknown",
                           "Could not check Windows Update.")


# ---------------------------------------------------------------------------
# check_registry_app  — fixed MOZA launch path logic
# ---------------------------------------------------------------------------

def check_registry_app(key, comp):
    approved  = comp.get("approved_version", "")
    reg_key   = comp.get("registry_key", "")
    reg_val   = comp.get("registry_value", "Version")
    installed = None
    exe_path  = None          # resolved Path to the installed exe

    if reg_key:
        reg_result = _reg_read(reg_key, "", reg_val)
        if reg_result:
            # Case A: registry value IS a full path to the exe (e.g. MOZA "path" key)
            if reg_result.endswith(".exe") or ("\\" in reg_result and Path(reg_result).suffix.lower() == ".exe"):
                candidate = Path(reg_result)
                if candidate.exists():
                    exe_path  = candidate
                    installed = _get_exe_version(candidate)
            else:
                # Case B: registry value is a plain version string
                installed = reg_result

    # Fallback: build path from install_path_hint + exe_name
    if not installed or not exe_path:
        hint = comp.get("install_path_hint", "")
        exe  = comp.get("exe_name", "")
        if hint and exe:
            candidate = Path(hint) / exe
            if candidate.exists():
                exe_path = candidate
                if not installed:
                    installed = _get_exe_version(candidate)

    if not installed:
        return CheckResult(key, comp["label"],
                           "unknown",
                           "Not installed", approved,
                           f"{comp['label']} not found.",
                           comp.get("update_url", ""))

    # Build the action: prefer launching the local exe directly
    action = f"launch_exe:{exe_path}" if exe_path and exe_path.exists() else comp.get("update_url", "")

    if ver_gte(installed, approved):
        return CheckResult(key, comp["label"], "ok",
                           installed, approved,
                           f"{comp['label']} is current ({installed}).",
                           action)
    else:
        return CheckResult(key, comp["label"], "warning",
                           installed, approved,
                           f"Update available: {installed} -> {approved}",
                           action)


