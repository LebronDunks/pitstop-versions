def show_toast(title: str, message: str):
    try:
        root  = _get_tk_root()
        toast = tk.Toplevel(root)
        toast.overrideredirect(True)
        toast.attributes("-topmost", True)
        toast.configure(bg=C_HOVER)
        TOAST_W = 320
        tk.Label(toast, text=f"  ⚠  {title}",
                 font=tkfont.Font(family="DM Sans", size=10, weight="bold"),
                 bg=C_RED, fg=C_TEXT, anchor="w",
                 padx=10, pady=8, width=TOAST_W).pack(fill="x")
        tk.Label(toast, text=message,
                 font=tkfont.Font(family="DM Sans", size=9),
                 bg=C_PANEL, fg=C_TEXT,
                 wraplength=TOAST_W - 24,
                 justify="left", padx=12, pady=10).pack(fill="x")
        toast.update()
        w  = TOAST_W
        h  = toast.winfo_reqheight()
        sw = toast.winfo_screenwidth()
        sh = toast.winfo_screenheight()
        x  = sw - w - 16
        y  = sh - h - 60
        toast.geometry(f"{w}x{h}+{x}+{y}")
        toast.after(8000, toast.destroy)
        root.wait_window(toast)
    except Exception as exc:
        log.warning("Toast failed: %s", exc)

_popup_lock = threading.Lock()
