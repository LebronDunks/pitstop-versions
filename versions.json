"""
PitStop — Startup Installer
============================
Registers PitStop.exe to launch at Windows startup and writes the
rig profile + optional add-ons to the app config file.

Usage:
    python install_startup.py --profile asetek-build
    python install_startup.py --profile moza-simucube-pedals-build --addons streamdeck

Valid profiles:
    dev

    -- Asetek wheelbase --
    asetek-build                    (Asetek + Heusinkveld pedals)
    asetek-moza-pedals-build        (Asetek + MOZA pedals)
    asetek-simucube-pedals-build    (Asetek + Simucube Active Pedals)

    -- MOZA wheelbase --
    moza-build                      (MOZA wheelbase + MOZA pedals)
    moza-heusinkveld-build          (MOZA + Heusinkveld pedals)
    moza-simucube-pedals-build      (MOZA + Simucube Active Pedals)

    -- Simucube wheelbase --
    simucube-build                  (Simucube wheelbase + Simucube pedals)
    simucube-heusinkveld-build      (Simucube + Heusinkveld pedals)
    simucube-moza-pedals-build      (Simucube + MOZA pedals)

    -- Fanatec wheelbase --
    fanatec-build                   (Fanatec + Heusinkveld pedals)
    fanatec-moza-pedals-build       (Fanatec + MOZA pedals)
    fanatec-simucube-pedals-build   (Fanatec + Simucube Active Pedals)

Valid add-ons:
    streamdeck
    sensit
"""

import argparse
import json
import os
import sys
import winreg
from pathlib import Path


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

VALID_PROFILES = [
    "dev",
    # Asetek wheelbase
    "asetek-build",
    "asetek-moza-pedals-build",
    "asetek-simucube-pedals-build",
    # MOZA wheelbase
    "moza-build",
    "moza-heusinkveld-build",
    "moza-simucube-pedals-build",
    # Simucube wheelbase
    "simucube-build",
    "simucube-heusinkveld-build",
    "simucube-moza-pedals-build",
    # Fanatec wheelbase
    "fanatec-build",
    "fanatec-moza-pedals-build",
    "fanatec-simucube-pedals-build",
]

VALID_ADDONS = ["streamdeck", "sensit"]

APP_NAME    = "PitStop"
APP_DIR     = Path(os.getenv("APPDATA")) / "Podium1" / "PitStop"
CONFIG_FILE = APP_DIR / "config.json"

# Startup registry key (per-user, no admin needed)
STARTUP_REG_KEY = r"SOFTWARE\Microsoft\Windows\CurrentVersion\Run"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def resolve_exe() -> Path:
    """
    Find PitStop.exe relative to this script.
    Works whether run from the source tree (dist/PitStop.exe)
    or from an already-extracted PyInstaller bundle (same directory).
    """
    candidates = [
        Path(sys.executable).parent / "PitStop.exe",   # bundled alongside installer
        Path(__file__).parent / "dist" / "PitStop.exe", # dev tree after pyinstaller build
        Path(__file__).parent / "PitStop.exe",           # flat layout
    ]
    for c in candidates:
        if c.exists():
            return c.resolve()
    return candidates[1]   # return the expected path even if not yet built


def write_config(profile: str, addons: list[str]):
    APP_DIR.mkdir(parents=True, exist_ok=True)
    cfg = {
        "profile": profile,
        "addons":  addons,
        "installed_at": str(Path(__file__).resolve()),
    }
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))
    print(f"  Config written to: {CONFIG_FILE}")


def register_startup(exe_path: Path):
    """Add PitStop.exe to HKCU Run key so it starts with Windows."""
    try:
        with winreg.OpenKey(
            winreg.HKEY_CURRENT_USER,
            STARTUP_REG_KEY,
            0,
            winreg.KEY_SET_VALUE,
        ) as key:
            winreg.SetValueEx(key, APP_NAME, 0, winreg.REG_SZ, f'"{exe_path}"')
        print(f"  Startup registry entry set: {exe_path}")
        return True
    except Exception as exc:
        print(f"  WARNING: Could not write startup registry key: {exc}")
        print(f"  You can manually add: {exe_path}")
        return False


def unregister_startup():
    """Remove PitStop from startup (useful for clean reinstall)."""
    try:
        with winreg.OpenKey(
            winreg.HKEY_CURRENT_USER,
            STARTUP_REG_KEY,
            0,
            winreg.KEY_SET_VALUE,
        ) as key:
            winreg.DeleteValue(key, APP_NAME)
        print("  Removed existing startup entry.")
    except FileNotFoundError:
        pass
    except Exception as exc:
        print(f"  Warning removing startup entry: {exc}")


def unblock_exe(exe_path: Path):
    """
    Remove the Zone.Identifier alternate data stream that Windows attaches
    to downloaded files, and add the exe to the Windows Security exclusions
    so Smart App Control / Defender does not block it.
    """
    # Step 1: Unblock the file (removes the "downloaded from internet" flag)
    try:
        import subprocess
        subprocess.run(
            ["powershell", "-NonInteractive", "-NoProfile", "-command",
             f"Unblock-File -Path '{exe_path}'"],
            timeout=10, check=True
        )
        print(f"  File unblocked: {exe_path}")
    except Exception as exc:
        print(f"  Note: Could not unblock file: {exc}")

    # Step 2: Add exe folder to Windows Defender exclusions
    # This prevents Smart App Control from interfering on future launches
    try:
        exe_dir = str(exe_path.parent)
        subprocess.run(
            ["powershell", "-NonInteractive", "-NoProfile", "-command",
             f"Add-MpPreference -ExclusionPath '{exe_dir}'"],
            timeout=15, check=True
        )
        print(f"  Windows Security exclusion added: {exe_dir}")
    except Exception as exc:
        print(f"  Note: Could not add Windows Security exclusion: {exc}")
        print(f"  You may need to add manually: Settings > Windows Security > Exclusions")


def disable_smart_app_control():
    """
    Disable Windows Smart App Control so PitStop can launch without being blocked.
    Smart App Control is a consumer feature not appropriate for managed business rigs.
    Requires admin rights.
    """
    import subprocess
    try:
        subprocess.run(
            ["powershell", "-NonInteractive", "-NoProfile", "-command",
             r"Set-ItemProperty -Path 'HKLM:\SYSTEM\CurrentControlSet\Control\CI\Policy' "
             "-Name 'VerifiedAndReputablePolicyState' -Value 0 -Force"],
            timeout=15, check=True
        )
        print("  Smart App Control disabled.")
    except Exception as exc:
        print(f"  Note: Could not disable Smart App Control: {exc}")

    # Also disable via the SmartScreen registry key as a second layer
    try:
        import winreg
        with winreg.OpenKey(
            winreg.HKEY_LOCAL_MACHINE,
            r"SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer",
            0,
            winreg.KEY_SET_VALUE,
        ) as key:
            winreg.SetValueEx(key, "SmartScreenEnabled", 0, winreg.REG_SZ, "Off")
        print("  SmartScreen policy set to off.")
    except Exception as exc:
        print(f"  Note: Could not set SmartScreen policy: {exc}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Install PitStop and configure it for this rig.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "--profile",
        required=True,
        choices=VALID_PROFILES,
        metavar="PROFILE",
        help=f"Rig profile. One of: {', '.join(VALID_PROFILES)}",
    )
    parser.add_argument(
        "--addons",
        nargs="*",
        default=[],
        choices=VALID_ADDONS + [""],
        metavar="ADDON",
        help=f"Optional add-ons. Any of: {', '.join(VALID_ADDONS)}",
    )
    parser.add_argument(
        "--uninstall",
        action="store_true",
        help="Remove PitStop from startup (does not delete files).",
    )

    args = parser.parse_args()
    addons = [a for a in (args.addons or []) if a in VALID_ADDONS]

    # Auto-elevate to admin if not already running elevated
    import ctypes
    if not ctypes.windll.shell32.IsUserAnAdmin():
        print("  Requesting administrator privileges...")
        # Find the actual python.exe — not the py launcher
        python_exe = Path(sys.executable)
        if python_exe.name.lower() in ("py.exe", "py3.exe"):
            # Running via py launcher — find the real python.exe
            import subprocess
            result = subprocess.run(
                ["py", "-3.12", "-c", "import sys; print(sys.executable)"],
                capture_output=True, text=True
            )
            python_exe = Path(result.stdout.strip())

        params = f'--profile {args.profile}'
        if addons:
            params += f' --addons {" ".join(addons)}'
        if args.uninstall:
            params += ' --uninstall'
        script = str(Path(__file__).resolve())
        ret = ctypes.windll.shell32.ShellExecuteW(
            None, "runas", str(python_exe),
            f'"{script}" {params}', None, 1
        )
        if ret > 32:
            sys.exit(0)  # Re-launched as admin — exit this instance
        print("  WARNING: Could not elevate. Continuing without admin rights.")
        print("  Windows Security exclusion may not be applied.")

    print(f"\n{'='*50}")
    print(f"  PitStop — Podium 1 Racing")
    print(f"{'='*50}")

    if args.uninstall:
        print("\n  Removing PitStop from startup…")
        unregister_startup()
        print("  Done. PitStop will no longer start with Windows.")
        print("  (Files in AppData\\Podium1\\PitStop were not deleted.)")
        return

    exe = resolve_exe()
    print(f"\n  Profile : {args.profile}")
    print(f"  Add-ons : {', '.join(addons) if addons else '(none)'}")
    print(f"  Exe     : {exe}")
    print()

    # 1. Write config
    write_config(args.profile, addons)

    # 2. Remove stale startup entry, then re-add
    unregister_startup()
    ok = register_startup(exe)

    # 3. Unblock exe, disable Smart App Control, add Windows Security exclusion
    print("  Configuring Windows Security...")
    disable_smart_app_control()
    unblock_exe(exe)

    print()
    if ok:
        print("  ✅  PitStop installed successfully!")
        print(f"  It will start automatically next time Windows boots.")
        print(f"  To start it now: double-click PitStop.exe or run it from the tray area.")
    else:
        print("  ⚠️   Config saved but startup registration failed.")
        print(f"  Manually run: {exe}")

    print()


if __name__ == "__main__":
    main()
