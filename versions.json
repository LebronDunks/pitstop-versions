def check_asetek_racehub(comp):
    # RaceHub version detection strategy:
    # The user-facing app version (e.g. 4.4.7) is encoded in the name of the
    # firmware versions text file inside the Firmware Files folder:
    #   "4.4.7 - Firmware Versions"  (Text Document, no .txt shown in Explorer)
    # Path: <install_path_hint>/../Firmware Update Tools/Firmware Files/
    # install_path_hint points to .../Application Folder/Build, so one .parent
    # reaches Application Folder, then we descend into Firmware Update Tools.

    approved     = comp.get("approved_version", "")
    hint         = comp.get("install_path_hint",
                             r"C:\Program Files\Asetek SimSports\RaceHub™\Application Folder\Build")
    exe_name     = comp.get("exe_name", "RaceHub™.exe")
    exe_path     = Path(hint) / exe_name
    firmware_dir = Path(hint).parent / "Firmware Update Tools" / "Firmware Files"
    installed    = None

    # Parse app version from firmware versions filename
    if firmware_dir.exists():
        for f in firmware_dir.iterdir():
            if "Firmware Versions" in f.name:
                # Filename is "4.4.7 - Firmware Versions" or "4.4.7 - Firmware Versions.txt"
                stem = f.stem
                parts = stem.split(" - ", 1)
                candidate = parts[0].strip()
                if candidate.replace(".", "").isdigit():
                    installed = candidate
                    break

    # If version file not found, fall back to checking exe exists
    if not installed and not exe_path.exists():
        return CheckResult("asetek_racehub", comp["label"],
                           "unknown", "Not installed", approved,
                           f"{comp['label']} not found.",
                           comp.get("update_url", ""))

    if not installed:
        installed = "Unknown"

    action = f"launch_exe:{exe_path}" if exe_path.exists() else comp.get("update_url", "")

    if installed != "Unknown" and ver_gte(installed, approved):
        return CheckResult("asetek_racehub", comp["label"], "ok",
                           installed, approved,
                           f"{comp['label']} is current ({installed}).", action)
    elif installed == "Unknown":
        return CheckResult("asetek_racehub", comp["label"], "unknown",
                           installed, approved,
                           f"{comp['label']} installed but version could not be determined.", action)
    else:
        return CheckResult("asetek_racehub", comp["label"], "warning",
                           installed, approved,
                           f"Update available: {installed} -> {approved}", action)


def check_simhub(comp):
    # SimHub's exe FileVersion is 1.0.0.0 and does not match the displayed version.
    # SimHub writes "Starting SimHub vX.X.X" to its log on every launch.
    # We parse that line from the log as it is the most reliable source.
    approved = comp.get("approved_version", "")
    hint     = comp.get("install_path_hint", r"C:\Program Files (x86)\SimHub")
    exe_name = comp.get("exe_name", "SimHubWPF.exe")
    exe_path = Path(hint) / exe_name
    log_path = Path(hint) / "Logs" / "SimHub.txt"
    installed = None

    # Parse version from log file - look for "Starting SimHub vX.X.X"
    if log_path.exists():
        try:
            with open(log_path, encoding="utf-8", errors="replace") as lf:
                for line in lf:
                    if "Starting SimHub v" in line:
                        # Extract version after "Starting SimHub v"
                        idx = line.index("Starting SimHub v") + len("Starting SimHub v")
                        ver = line[idx:].split()[0].strip()
                        if ver:
                            installed = ver
                            break
        except Exception as exc:
            log.warning("SimHub log parse failed: %s", exc)

    if not installed and not exe_path.exists():
        return CheckResult("simhub", comp["label"],
                           "unknown", "Not installed", approved,
                           f"{comp['label']} not found.",
                           comp.get("update_url", ""))

    if not installed:
        installed = "Unknown"

    action = f"launch_exe:{exe_path}" if exe_path.exists() else comp.get("update_url", "")

    if installed != "Unknown" and ver_gte(installed, approved):
        return CheckResult("simhub", comp["label"], "ok",
                           installed, approved,
                           f"{comp['label']} is current ({installed}).", action)
    elif installed == "Unknown":
        return CheckResult("simhub", comp["label"], "unknown",
                           installed, approved,
                           f"{comp['label']} installed but version could not be determined.", action)
    else:
        return CheckResult("simhub", comp["label"], "warning",
                           installed, approved,
                           f"Update available: {installed} -> {approved}", action)


def _run_ps(command: str) -> str:
    return _silent_ps(
        ["powershell", "-NonInteractive", "-NoProfile", "-WindowStyle", "Hidden",
         "-command", command],
        timeout=20,
    )

def diag_usb_disconnects() -> DiagResult:
    try:
        ps = (
            "$since = (Get-Date).AddDays(-7);"
            "$events = Get-WinEvent -FilterHashtable @{LogName='System'; Id=7; StartTime=$since} -ErrorAction SilentlyContinue;"
            "if ($events) { $events.Count } else { 0 }"
        )
        count_str = _run_ps(ps)
        count = int(count_str) if count_str.isdigit() else 0
        if count == 0:
            return DiagResult("usb_disconnects", "USB devices", "clear", "No USB disconnect events in the last 7 days.")
        elif count <= 3:
            return DiagResult("usb_disconnects", "USB disconnect events", "warning",
                              f"{count} USB disconnect event(s) in the last 7 days. Monitor for loose cables or power issues.")
        else:
            return DiagResult("usb_disconnects", "USB disconnecting repeatedly", "critical",
                              f"{count} USB disconnect events in the last 7 days. Check cables, USB hubs, and power settings.")
    except Exception as exc:
        log.warning("diag_usb_disconnects failed: %s", exc)
        return DiagResult("usb_disconnects", "USB devices", "info", "Could not check USB disconnect history.")

def diag_app_crashes() -> DiagResult:
    try:
        ps = (
            "$since = (Get-Date).AddDays(-7);"
            "$events = Get-WinEvent -FilterHashtable @{LogName='Application'; Id=1000; StartTime=$since} -ErrorAction SilentlyContinue;"
            "if ($events) { $events.Count } else { 0 }"
        )
        count_str = _run_ps(ps)
        count = int(count_str) if count_str.isdigit() else 0
        ps2 = (
            "$since = (Get-Date).AddDays(-7);"
            "$e = Get-WinEvent -FilterHashtable @{LogName='Application'; Id=1000; StartTime=$since} "
            "-MaxEvents 1 -ErrorAction SilentlyContinue;"
            "if ($e) { $e[0].TimeCreated.ToString('MMM dd h:mm tt') + '|' + "
            "([xml]$e[0].ToXml()).Event.EventData.Data[0] } else { '' }"
        )
        recent = _run_ps(ps2)
        recent_time, recent_app = (recent.split("|", 1) + ["", ""])[:2]
        if count == 0:
            return DiagResult("app_crashes", "Application crashes", "clear", "No app crashes detected in the last 7 days.")
        elif count <= 3:
            desc = f"{count} crash(es) in the last 7 days."
            if recent_app:
                desc += f" Most recent: {recent_app.strip()} ({recent_time})"
            return DiagResult("app_crashes", "Application crashes", "warning", desc, recent_time)
        else:
            desc = f"{count} crashes in the last 7 days — system may be unstable."
            if recent_app:
                desc += f" Most recent: {recent_app.strip()} ({recent_time})"
            return DiagResult("app_crashes", "Frequent app crashes", "critical", desc, recent_time)
    except Exception as exc:
        log.warning("diag_app_crashes failed: %s", exc)
        return DiagResult("app_crashes", "Application crashes", "info", "Could not check crash history.")

def diag_bsod() -> DiagResult:
    try:
        ps = (
            "$since = (Get-Date).AddDays(-30);"
            "$events = Get-WinEvent -FilterHashtable @{LogName='System'; Id=41; StartTime=$since} -ErrorAction SilentlyContinue;"
            "if ($events) { $events[0].TimeCreated.ToString('MMM dd yyyy') + '|' + $events.Count } else { '' }"
        )
        result = _run_ps(ps)
        if not result:
            return DiagResult("bsod", "Blue screen (BSOD)", "clear", "No blue screen events in the last 30 days.")
        parts  = result.split("|", 1)
        recent = parts[0].strip()
        count  = int(parts[1].strip()) if len(parts) > 1 and parts[1].strip().isdigit() else 1
        return DiagResult("bsod", "Blue screen (BSOD)", "critical",
                          f"{count} BSOD event(s) in the last 30 days. Most recent: {recent}. Check drivers and hardware.", recent)
    except Exception as exc:
        log.warning("diag_bsod failed: %s", exc)
        return DiagResult("bsod", "Blue screen (BSOD)", "info", "Could not check BSOD history.")

def diag_dirty_shutdown() -> DiagResult:
    try:
        ps = (
            "$e = Get-WinEvent -FilterHashtable @{LogName='System'; Id=6008} "
            "-MaxEvents 1 -ErrorAction SilentlyContinue;"
            "if ($e) { $e[0].TimeCreated.ToString('MMM dd yyyy h:mm tt') } else { '' }"
        )
        result = _run_ps(ps)
        if not result:
            return DiagResult("dirty_shutdown", "Unexpected shutdowns", "clear", "No unexpected shutdowns detected.")
        return DiagResult("dirty_shutdown", "Unexpected shutdown detected", "warning",
                          f"System did not shut down cleanly. Last occurrence: {result}. Could indicate a crash or power loss.", result)
    except Exception as exc:
        log.warning("diag_dirty_shutdown failed: %s", exc)
        return DiagResult("dirty_shutdown", "Unexpected shutdowns", "info", "Could not check shutdown history.")

def diag_pending_reboot() -> DiagResult:
    try:
        keys_to_check = [
            r"HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired",
            r"HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing\RebootPending",
        ]
        pending = False
        for key in keys_to_check:
            parts = key.split("\\", 1)
            hive  = winreg.HKEY_LOCAL_MACHINE
            try:
                with winreg.OpenKey(hive, parts[1]):
                    pending = True
                    break
            except Exception:
                continue
        if pending:
            return DiagResult("pending_reboot", "Reboot required", "warning",
                              "Windows is waiting for a reboot to finish applying updates. Reboot the rig when possible.")
        return DiagResult("pending_reboot", "Reboot status", "clear", "No pending reboot required.")
    except Exception as exc:
        log.warning("diag_pending_reboot failed: %s", exc)
        return DiagResult("pending_reboot", "Reboot status", "info", "Could not check reboot status.")

def diag_disk_space() -> DiagResult:
    try:
        import shutil
        low_drives = []
        for drive_letter in "CDEFGH":
            drive = f"{drive_letter}:\\"
            if Path(drive).exists():
                total, used, free = shutil.disk_usage(drive)
                free_gb = free / (1024 ** 3)
                if free_gb < 20:
                    low_drives.append(f"{drive_letter}: ({free_gb:.1f} GB free)")
        if not low_drives:
            return DiagResult("disk_space", "Disk space", "clear", "All drives have sufficient free space.")
        elif len(low_drives) == 1:
            return DiagResult("disk_space", "Low disk space", "warning",
                              f"Drive {low_drives[0]} is running low. Less than 20 GB free can cause sim issues.")
        else:
            return DiagResult("disk_space", "Low disk space", "critical",
                              f"Multiple drives low: {', '.join(low_drives)}. Free up space to avoid crashes and stuttering.")
    except Exception as exc:
        log.warning("diag_disk_space failed: %s", exc)
        return DiagResult("disk_space", "Disk space", "info", "Could not check disk space.")

def diag_gpu_temp() -> DiagResult:
    try:
        out = subprocess.check_output(
            ["nvidia-smi", "--query-gpu=temperature.gpu", "--format=csv,noheader"],
            timeout=10, creationflags=subprocess.CREATE_NO_WINDOW,
        ).decode().strip().split("\n")[0].strip()
        temp = int(out)
        if temp >= 90:
            return DiagResult("gpu_temp", "GPU temperature", "critical",
                              f"GPU is running at {temp}°C — critically hot. Check case airflow and GPU cooler immediately.")
        elif temp >= 80:
            return DiagResult("gpu_temp", "GPU temperature", "warning",
                              f"GPU is running at {temp}°C — above recommended range. Monitor airflow and ensure adequate cooling.")
        else:
            return DiagResult("gpu_temp", "GPU temperature", "clear", f"GPU temperature is {temp}°C — within normal range.")
    except Exception as exc:
        log.warning("diag_gpu_temp failed: %s", exc)
        return DiagResult("gpu_temp", "GPU temperature", "info", "Could not read GPU temperature.")

def diag_system_uptime() -> DiagResult:
    try:
        import ctypes
        tick_ms  = ctypes.windll.kernel32.GetTickCount64()
        uptime_s = tick_ms / 1000
        days     = int(uptime_s // 86400)
        hours    = int((uptime_s % 86400) // 3600)
        if days >= 14:
            return DiagResult("uptime", "System uptime", "warning",
                              f"Rig has been running for {days} days without a reboot. A reboot is recommended to clear memory and apply updates.",
                              f"{days}d {hours}h uptime")
        else:
            return DiagResult("uptime", "System uptime", "info",
                              f"System has been running for {days} days, {hours} hours.",
                              f"{days}d {hours}h uptime")
    except Exception as exc:
        log.warning("diag_system_uptime failed: %s", exc)
        return DiagResult("uptime", "System uptime", "info", "Could not check system uptime.")

def diag_network_errors() -> DiagResult:
    try:
        ps = (
            "$since = (Get-Date).AddDays(-7);"
            "$events = Get-WinEvent -FilterHashtable @{LogName='System'; "
            "ProviderName='e1iexpress','nvlddmkm','tcpip'; StartTime=$since} "
            "-ErrorAction SilentlyContinue;"
            "if ($events) { $events.Count } else { 0 }"
        )
        count_str = _run_ps(ps)
        count = int(count_str) if count_str.isdigit() else 0
        if count == 0:
            return DiagResult("network_errors", "Network adapter", "clear", "No network adapter errors in the last 7 days.")
        else:
            return DiagResult("network_errors", "Network adapter errors", "warning",
                              f"{count} network error event(s) in the last 7 days. May cause connection drops during online racing.")
    except Exception as exc:
        log.warning("diag_network_errors failed: %s", exc)
        return DiagResult("network_errors", "Network adapter", "info", "Could not check network error history.")

def diag_cpu_temp() -> DiagResult:
    try:
        ps = (
            "$t = Get-WmiObject MSAcpi_ThermalZoneTemperature -Namespace 'root/wmi' "
            "-ErrorAction SilentlyContinue | Select-Object -First 1 CurrentTemperature;"
            "if ($t) { [math]::Round($t.CurrentTemperature / 10 - 273.15) } else { '' }"
        )
        result = _run_ps(ps)
        if not result or not result.lstrip("-").isdigit():
            return DiagResult("cpu_temp", "CPU temperature", "info", "CPU temperature sensor not accessible on this system.")
        temp = int(result)
        if temp >= 95:
            return DiagResult("cpu_temp", "CPU temperature", "critical",
                              f"CPU is running at {temp}°C — critically hot. Check CPU cooler and case airflow immediately.")
        elif temp >= 80:
            return DiagResult("cpu_temp", "CPU temperature", "warning",
                              f"CPU is running at {temp}°C — above recommended range.")
        else:
            return DiagResult("cpu_temp", "CPU temperature", "clear", f"CPU temperature is {temp}°C — normal.")
    except Exception as exc:
        log.warning("diag_cpu_temp failed: %s", exc)
        return DiagResult("cpu_temp", "CPU temperature", "info", "Could not read CPU temperature.")

def run_diagnostics() -> list:
    log.info("Running diagnostics...")
    checks = [
        diag_usb_disconnects, diag_app_crashes, diag_bsod, diag_dirty_shutdown,
        diag_pending_reboot, diag_disk_space, diag_gpu_temp, diag_cpu_temp,
        diag_system_uptime, diag_network_errors,
    ]
    results = []
    for check in checks:
        try:
            results.append(check())
        except Exception as exc:
            log.exception("Diagnostic failed: %s", exc)
    log.info("Diagnostics complete — %d checks run", len(results))
    return results

def perform_action(action: str):
    if not action:
        return
    if action.startswith("launch_exe:"):
        exe_path = Path(action[len("launch_exe:"):].replace("/", "\\"))
        if exe_path.exists():
            subprocess.Popen([str(exe_path)])
        else:
            log.warning("Launch failed — exe not found: %s", exe_path)
    elif action.endswith(".exe"):
        exe_path = Path(action.replace("/", "\\"))
        if exe_path.exists():
            subprocess.Popen([str(exe_path)])
        else:
            log.warning("Launch failed — exe not found: %s", exe_path)
    elif action.startswith("http"):
        import webbrowser
        webbrowser.open(action)
    elif action == "open_nvidia_app":
        # Try to open NVIDIA App directly to the drivers tab
        nvidia_paths = [
            r"C:\Program Files\NVIDIA Corporation\NVIDIA App\CEF\NVIDIA App.exe",
            r"C:\Program Files\NVIDIA Corporation\NVIDIA app\CEF\NVIDIA app.exe",
        ]
        launched = False
        for p in nvidia_paths:
            if Path(p).exists():
                subprocess.Popen([p], creationflags=subprocess.CREATE_NO_WINDOW)
                launched = True
                break
        if not launched:
            import webbrowser
            webbrowser.open("https://www.nvidia.com/en-us/software/nvidia-app/")
    elif action == "open_windows_update":
        # Open Windows Update settings directly
        subprocess.Popen(
            ["powershell", "-WindowStyle", "Hidden", "-command",
             "Start-Process 'ms-settings:windowsupdate'"],
            creationflags=subprocess.CREATE_NO_WINDOW
        )

REGISTRY_APPS = {
    "moza_pithouse", "simucube_truedrive",
    "heusinkveld_app", "streamdeck", "sensit_haptics",
}

def run_checks_func() -> list:
    manifest = fetch_manifest()
    if not manifest:
        log.error("No manifest available.")
        return []
    components_def = manifest.get("components", {})
    profiles_def   = manifest.get("profiles", {})
    addons_def     = manifest.get("addons", {})
    profile_name, enabled_addons = get_profile()
    profile     = profiles_def.get(profile_name, {})
    active_keys = list(profile.get("components", []))
    for addon_key in enabled_addons:
        comp_key = addons_def.get(addon_key, {}).get("component")
        if comp_key and comp_key not in active_keys:
            active_keys.append(comp_key)
    if not active_keys:
        log.warning("No components found for profile: %s", profile_name)
    results = []
    for key in active_keys:
        comp = components_def.get(key)
        if not comp:
            continue
        log.info("Checking: %s", key)
        try:
            if key == "nvidia_driver":
                r = check_nvidia_driver(comp)
            elif key == "windows_update":
                r = check_windows_update(comp)
            elif key == "asetek_racehub":
                r = check_asetek_racehub(comp)
            elif key == "simucube_tuner":
                r = check_simucube_tuner(comp)
            elif key == "fanatec_app":
                r = check_fanatec_app(comp)
            elif key == "simhub":
                r = check_simhub(comp)
            elif key in REGISTRY_APPS:
                r = check_registry_app(key, comp)
            else:
                log.warning("No checker for: %s", key)
                continue
            results.append(r)
        except Exception as exc:
            log.exception("Check failed for %s: %s", key, exc)
            results.append(CheckResult(key, comp.get("label", key), "unknown", "Error", "",
                                       f"Check failed: {exc}"))
    return results

def overall_status(results: list) -> str:
    for r in results:
        if r.status == "warning":
            return "yellow"
        if r.status == "error" and r.installed != "Not installed":
            return "red"
    return "green"

